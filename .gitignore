# --- credentials & secrets (NEVER commit) ---
credentials.txt
*.credentials
*.secret
*.key
*.pem
.env
.env.*
!.env.example

# --- nested gitlab repo: now tracked as a git submodule ---
# pdp-project-24/ is a git submodule pointing at the GitLab course repo
# (gitlab.ewi.tudelft.nl). Cloning this GitHub repo gets you the pointer;
# run `git submodule update --init --recursive` to fetch the GitLab
# content. The submodule URL is HTTPS so it works with the PAT in
# credentials.txt.

# --- FPGA build artifacts (regenerated by Vivado) ---
artifacts/
*.bit
*.bif
*.hwh
*.ltx
*.bin
*.mcs
*.prm

# --- Vivado / Xilinx run scratch ---
.Xil/
*.jou
*.log
*.str
*.pb
*.wdb
*.wcfg
*.dcp
vivado*.backup.jou
vivado*.backup.log
webtalk*.jou
webtalk*.log
hd_visual/
.cache/
.hbs/

# --- toolchain build outputs ---
output/
build/
*.elf
*.coe
*.o
*.a
*.so
*.exe

# --- SSHFS mount target (lives at $HOME by default but guard against in-tree) ---
pdp-server-mnt/

# --- editor / OS junk ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.bak
*.tmp

# --- python venvs (in case anyone adds tooling) ---
__pycache__/
*.pyc
.venv/
venv/
