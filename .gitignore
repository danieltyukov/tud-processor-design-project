# --- credentials & secrets (NEVER commit) ---
credentials.txt
*.credentials
*.secret
*.key
*.pem
.env
.env.*
!.env.example

# --- nested gitlab repo (separate origin; clone separately) ---
# pdp-project-24/ has its own .git pointing at gitlab.ewi.tudelft.nl.
# Teammates clone it into this path; see README.md for the command.
pdp-project-24/

# --- FPGA build artifacts (regenerated by Vivado) ---
artifacts/
*.bit
*.bif
*.hwh
*.ltx
*.bin
*.mcs
*.prm

# --- Vivado / Xilinx run scratch ---
.Xil/
*.jou
*.log
*.str
*.pb
*.wdb
*.wcfg
*.dcp
vivado*.backup.jou
vivado*.backup.log
webtalk*.jou
webtalk*.log
hd_visual/
.cache/
.hbs/

# --- toolchain build outputs ---
output/
build/
*.elf
*.coe
*.o
*.a
*.so
*.exe

# --- SSHFS mount target (lives at $HOME by default but guard against in-tree) ---
pdp-server-mnt/

# --- editor / OS junk ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.bak
*.tmp

# --- python venvs (in case anyone adds tooling) ---
__pycache__/
*.pyc
.venv/
venv/
