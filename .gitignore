# --- credentials & secrets (NEVER commit) ---
credentials.txt
*.credentials
*.secret
*.key
*.pem
.env
.env.*
!.env.example

# --- pdp-project-24/ is a git subtree synced from the PDP server ---
# Server source of truth: cese4040-24@ce-procdesign01.ewi.tudelft.nl:pdp-project
# Pull updates from server:
#   git fetch pdp-server
#   git subtree pull --prefix=pdp-project-24 pdp-server main --squash
# Push everything (workspace + pdp-project-24 contents) to GitHub:
#   git push origin main

# --- FPGA build artifacts (regenerated by Vivado) ---
